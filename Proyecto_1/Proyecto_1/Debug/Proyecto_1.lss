0002ba 9508                      	RET
                                 
                                 APAGAR_DIGITOS:
                                 
                                 	// Apagamos para evitar ghosting
0002bb 985a                      	CBI		PORTD, PORTD2 // DIG1
0002bc 985b                      	CBI		PORTD, PORTD3 // DIG2
0002bd 985c                      	CBI		PORTD, PORTD4 // DIG3
