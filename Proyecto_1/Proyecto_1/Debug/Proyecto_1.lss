0001f1 1720                      	CP		R18, R16
0001f2 f010                      	BRLO	GUARDAR_DIA_INC
0001f3 f009                      	BREQ	GUARDAR_DIA_INC
                                 
0001f4 e021                      	LDI		R18, 1
                                 
