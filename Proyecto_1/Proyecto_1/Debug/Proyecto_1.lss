                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 * NombreProgra.asm
                                 *
                                 * Creado: 02/03/2026
                                 * Autor : Julian Alonso
                                 * Descripción: Proyecto 1.
                                 
                                  Encabezado (Definición de Registros, Variables y Constantes)
                                 .include "M328PDEF.inc"      Include definitions specific to ATMega328P
                                 
                                 */
                                 
                                 //----------MODOS-------------------/
                                 .equ	MODE_CLOCK		= 0
                                 .equ	MODE_SET_CLOCK	= 1
                                 .equ	MODE_DATE		= 2
                                 .equ	MODE_SET_DATE	= 3
                                 .equ	MODE_SET_ALARM	= 4
                                 .equ	MODE_RING		= 5
                                 .equ	MAX_MODES		= 5
                                 
                                 //----------BANDERAS---------------/
                                 .equ	FLAG_PCINT		= 0
                                 .equ	FLAG_TIMER_1	= 1
                                 
                                 //----------DATOS-----------------/
                                 .equ	T0VALUE			= 0x7C // Prescaler de 8
                                 .equ	T1VALUE			= 0x3D08 // Prescaler de 64
                                 
                                 //----------PATRONES DE SEGMENTOS-----------------/
                                 .equ	SEG_C		= 0b0111001
                                 .equ	SEG_L		= 0b0111000
                                 .equ	SEG_O		= 0b0111111
                                 .equ	SEG_d		= 0b1011110
                                 .equ	SEG_A		= 0b1110111
                                 .equ	SEG_t		= 0b1111000
                                 .equ	SEG_E		= 0b1111001
                                 .equ	SEG_S		= 0b1101101
                                 .equ	SEG_r		= 0b1010000
                                 .equ	SEG_I		= 0b0000110
                                 .equ	SEG_n		= 0b1010100
                                 .equ	SEG_G		= 0b0111101
                                 
                                 .equ	SEG_0		= 0b0111111
                                 .equ	SEG_1		= 0b0000110
                                 .equ	SEG_2		= 0b1011011
                                 .equ	SEG_3		= 0b1001111
                                 .equ	SEG_4		= 0b1100110
                                 .equ	SEG_5		= 0b1101101
                                 .equ	SEG_6		= 0b1111101
                                 .equ	SEG_7		= 0b0000111
                                 .equ	SEG_8		= 0b1111111
                                 .equ	SEG_9		= 0b1101111
                                 
                                 //----------REGISTROS-----------------/
                                 .def	MODE			= R20
                                 .def	ACTION			= R21
                                 
                                 .dseg
                                 .org    SRAM_START
                                 
                                 // -----------DISPLAY------------/
000100                           DISP0:		.byte 1
000101                           DISP1:		.byte 1
000102                           DISP2:		.byte 1
000103                           DISP3:		.byte 1
                                 
000104                           MUX:		.byte 1 // 0 - 3
                                 
000105                           MENSAJE:	.byte 1 // Mensaje de modo
000106                           MEN_LOW:	.byte 1
000107                           MEN_HIGH:	.byte 1
                                 
000108                           PREV_D7:	.byte 1 // Guarda el estado anterior
000109                           PUNTO_CONT:	.byte 1 // contador para parpadeo de :
00010a                           PUNTO_HALF:	.byte 1
                                 
00010b                           SEGUNDOS:	.byte 1
00010c                           MINUTOS:	.byte 1
00010d                           HORAS:		.byte 1
                                 
00010e                           DIA:		.byte 1
00010f                           MES:		.byte 1
                                 
000110                           AL_HORAS:	.byte 1
000111                           AL_MINUTOS:	.byte 1
000112                           AL_ACTIVA:	.byte 1
                                 
                                 //variable_name:     .byte   1   // Memory alocation for variable_name:     .byte   (byte size)
                                 
                                 .cseg
                                 .org 0x0000
                                 
000000 940c 001e                 	JMP		START
                                 .org	PCI1addr	// Interrupciones para puerto C
000008 940c 03f5                 	JMP		PINC_ISR
                                 
                                 .org	PCI2addr	// Interrupciones para puerto D
00000a 940c 03fd                 	JMP		PIND_ISR
                                 
                                 .org	OC1Aaddr	// Interrupciones para Timer 1 Compare match A
000016 940c 0405                 	JMP		TIMER1_ISR
                                 
                                 .org	OC0Aaddr	// Interrupciones para Timer 0Compare match A
00001c 940c 040d                 	JMP		TIMER0_ISR
                                 
                                 START:
                                  /****************************************/
                                 // Configuración de la pila
00001e ef0f                      LDI     R16, LOW(RAMEND)
00001f bf0d                      OUT     SPL, R16
000020 e008                      LDI     R16, HIGH(RAMEND)
000021 bf0e                      OUT     SPH, R16
                                 /****************************************/
                                 // Configuracion MCU
                                 SETUP:
                                 
                                 	// Configuramos el reloj a 1 MHz
000022 94f8                          CLI
000023 e800                      	LDI		R16, (1<< CLKPCE)
000024 9300 0061                 	STS		CLKPR, R16
000026 e004                      	LDI		R16, (1<< CLKPS2)
000027 9300 0061                 	STS		CLKPR, R16
                                 
                                 	// Iniciamos registros
000029 2744                      	CLR		MODE
00002a 2755                      	CLR		ACTION
                                 
                                 	// Llammamos para mostrar al inicio donde estamos
00002b 940e 027d                 	CALL	LOAD_MODE_MENSAJE
                                 
                                 	// Ponemos el mux en 0
00002d 2700                      	CLR		R16
00002e 9300 0104                 	STS		MUX, R16
                                 
                                 	// Iniciamos variables del reloj
000030 9300 010b                 	STS		SEGUNDOS, R16
000032 9300 010c                 	STS		MINUTOS, R16
000034 9300 0109                 	STS		PUNTO_CONT, R16
000036 9300 010a                 	STS		PUNTO_HALF, R16
                                 
                                 	// Inicializamos hora predeterminada
000038 e00c                      	LDI		R16, 12
000039 9300 010d                 	STS		HORAS, R16
                                 
                                 	// Inicializamos una fecha predeterminada
00003b e00a                      	LDI		R16, 10
00003c 9300 010e                 	STS		DIA, R16
00003e e003                      	LDI		R16, 3
00003f 9300 010f                 	STS		MES, R16
                                 
                                 		// Inicializamos alarma predeterminada
000041 e006                      	LDI		R16, 6
000042 9300 0110                 	STS		AL_HORAS, R16
                                 
000044 2700                      	CLR		R16
000045 9300 0111                 	STS		AL_MINUTOS, R16
000047 9300 0112                 	STS		AL_ACTIVA, R16
                                 
                                 	// Iniciaos mensaje para mostrar al inicio
000049 e001                      	LDI		R16, 1
00004a 9300 0105                 	STS		MENSAJE, R16
                                 
00004c ee08                      	LDI		R16, LOW(1000)
00004d 9300 0106                 	STS		MEN_LOW, R16
00004f e003                      	LDI		R16, HIGH(1000)
000050 9300 0107                 	STS		MEN_HIGH, R16
                                 
                                 	// Configuramos los botones con pullup
000052 983a                      	CBI		DDRC, DDC2
000053 983b                      	CBI		DDRC, DDC3
000054 983c                      	CBI		DDRC, DDC4
000055 983d                      	CBI		DDRC, DDC5
                                 
000056 9a42                      	SBI		PORTC, PORTC2
000057 9a43                      	SBI		PORTC, PORTC3
000058 9a44                      	SBI		PORTC, PORTC4
000059 9a45                      	SBI		PORTC, PORTC5
                                 
00005a 9857                      	CBI		DDRD, DDD7 // boton de modo
00005b 9a5f                      	SBI		PORTD, PORTD7
                                 
                                 	// Configuramos los leds del display apagados
00005c 9a20                      	SBI		DDRB, DDB0	// a
00005d 9a21                      	SBI		DDRB, DDB1	// b
00005e 9a22                      	SBI		DDRB, DDB2	// c
00005f 9a23                      	SBI		DDRB, DDB3	// d
000060 9a24                      	SBI		DDRB, DDB4	// e
000061 9a25                      	SBI		DDRB, DDB5	// f
000062 9a38                      	SBI		DDRC, DDC0	// g
000063 9a39                      	SBI		DDRC, DDC1	// : o DP
                                 
000064 9828                      	CBI		PORTB, PORTB0
000065 9829                      	CBI		PORTB, PORTB1
000066 982a                      	CBI		PORTB, PORTB2
000067 982b                      	CBI		PORTB, PORTB3
000068 982c                      	CBI		PORTB, PORTB4
000069 982d                      	CBI		PORTB, PORTB5
00006a 9840                      	CBI		PORTC, PORTC0
00006b 9841                      	CBI		PORTC, PORTC1
                                 
                                 	// Configuramos los bits de control
00006c 9a52                      	SBI		DDRD, DDD2 // DIG 1
00006d 9a53                      	SBI		DDRD, DDD3 // DIG 2
00006e 9a54                      	SBI		DDRD, DDD4 // DIG 3
00006f 9a55                      	SBI		DDRD, DDD5 // DIG 4
                                 
000070 985a                      	CBI		PORTD, PORTD2
000071 985b                      	CBI		PORTD, PORTD3
000072 985c                      	CBI		PORTD, PORTD4
000073 985d                      	CBI		PORTD, PORTD5
                                 
                                 	// Configuramos la alarma
000074 9a56                      	SBI		DDRD, DDD6
000075 985e                      	CBI		PORTD, PORTD6
                                 
                                 	// Habilitamos las interrupciones para PCINT
000076 e006                      	LDI		R16, (1 << PCIE1)|(1 << PCIE2)
000077 9300 0068                 	STS		PCICR, R16
                                 
000079 e30c                      	LDI		R16, (1<<PCINT10) | (1<<PCINT11) | (1<<PCINT12) | (1<<PCINT13)
00007a 9300 006c                 	STS		PCMSK1, R16
                                 
00007c e800                      	LDI		R16, (1<<PCINT23)
00007d 9300 006d                 	STS		PCMSK2, R16
                                 
                                 	// Llamamos a los timer
00007f 940e 0263                 	CALL	INIT_TIMER0
000081 940e 026d                 	CALL	INIT_TIMER1
                                 
                                 	// Guardamos el estado inicial del boton de modo
000083 b109                      	IN		R16, PIND
000084 9300 0108                 	STS		PREV_D7, R16
                                 
000086 9478                      	SEI // ENABLE GLOBAL INTERRUPCIONS
                                 
                                 /****************************************/
                                 // Loop Infinito
                                 MAIN_LOOP:
                                 	
                                 	// Si hay interrupcion por pin change procesamos los botones
000087 ff50                      	SBRS	ACTION, FLAG_PCINT
000088 c009                      	RJMP	NO_PCINT
                                 
                                 	// Limpiamos la bandera
000089 7f5e                      	CBR		ACTION, (1<<FLAG_PCINT)
                                 
                                 	// Funciona solo cuando sono la alarma
00008a 3045                      	CPI		MODE, MODE_RING
00008b f409                      	BRNE	REVISAR_MODO_NORMAL
00008c c003                      	RJMP	REVISAR_RING
                                 
                                 REVISAR_MODO_NORMAL:	
                                 	// Revisamos el boton de modo
00008d 940e 023d                 	CALL	CHECK_MODE_BUTTON
00008f c002                      	RJMP	NO_PCINT
                                 
                                 REVISAR_RING:
000090 940e 00db                 	CALL	CHECK_SILENCIO_RING
                                 
                                 NO_PCINT:
                                 
                                 	// Revisamos botones de ajuste
000092 940e 00af                 	CALL	CHECK_AJUSTES
                                 
                                 	// Si Timer1 dio tick de 1 segundo, actualizamos reloj
000094 ff51                      	SBRS	ACTION, FLAG_TIMER_1
000095 c005                      	RJMP	CHECK_ALARMA_LOOP
                                 
000096 7f5d                      	CBR		ACTION, (1<<FLAG_TIMER_1)
000097 940e 036b                 	CALL	ACTUALIZAR_RELOJ
000099 940e 00f1                 	CALL	RESET_ALARMA_CAMBIO_MINUTO
                                 
                                 CHECK_ALARMA_LOOP:
00009b 940e 00b9                 	CALL	CHECK_ALARM
00009d 940e 00d3                 	CALL	CONTROL_RING
00009f 940e 00db                 	CALL	CHECK_SILENCIO_RING
                                 
                                 CHECK_MENSAJE:
0000a1 9100 0105                 	LDS		R16, MENSAJE
0000a3 3001                      	CPI		R16, 1
0000a4 f011                      	BREQ	SALTAR_ACTUALIZACION
                                 
0000a5 940e 035b                 	CALL	ACTUALIZAR_DISPLAY
                                 
                                 SALTAR_ACTUALIZACION:
0000a7 cfdf                          RJMP    MAIN_LOOP
                                 
                                 
                                 /****************************************/
                                 // NON-Interrupt subroutines
                                 DELAY_REBOTE:
0000a8 e109                      	LDI		R16, 25
                                 
                                 REBOTE_LOOP1:
0000a9 e718                      	LDI		R17, 120
                                 
                                 REBOTE_LOOP2:
0000aa 951a                      	DEC		R17
0000ab f7f1                      	BRNE	REBOTE_LOOP2
                                 
0000ac 950a                      	DEC		R16
0000ad f7d9                      	BRNE	REBOTE_LOOP1
0000ae 9508                      	RET
                                 
                                 CHECK_AJUSTES:
0000af 3041                      	CPI		MODE, MODE_SET_CLOCK
0000b0 f409                      	BRNE	REVISAR_SET_DATE
0000b1 c047                      	RJMP	CHECK_SET_CLOCK
                                 
                                 REVISAR_SET_DATE:
0000b2 3043                      	CPI		MODE, MODE_SET_DATE
0000b3 f409                      	BRNE	REVISAR_SET_ALARM
0000b4 c051                      	RJMP	CHECK_SET_DATE
                                 
                                 REVISAR_SET_ALARM:
0000b5 3044                      	CPI		MODE, MODE_SET_ALARM
0000b6 f409                      	BRNE	SALIR_CHECK_AJUSTES
0000b7 c05b                      	RJMP	CHECK_SET_ALARM
                                 
                                 SALIR_CHECK_AJUSTES:
0000b8 9508                      	RET
                                 
                                 CHECK_ALARM:
                                 
0000b9 9100 0112                 	LDS		R16, AL_ACTIVA
0000bb 3001                      	CPI		R16, 1
0000bc f0a9                      	BREQ	SALIR_CHECK_ALARM
                                 
0000bd 9100 010d                 	LDS		R16, HORAS
0000bf 9110 0110                 	LDS		R17, AL_HORAS
0000c1 1701                      	CP		R16, R17
0000c2 f479                      	BRNE	SALIR_CHECK_ALARM
                                 
0000c3 9100 010c                 	LDS		R16, MINUTOS
0000c5 9110 0111                 	LDS		R17, AL_MINUTOS
0000c7 1701                      	CP		R16, R17
0000c8 f449                      	BRNE	SALIR_CHECK_ALARM
                                 
0000c9 9100 010b                 	LDS		R16, SEGUNDOS
0000cb 3000                      	CPI		R16, 0
0000cc f429                      	BRNE	SALIR_CHECK_ALARM
                                 
0000cd e001                      	LDI		R16, 1
0000ce 9300 0112                 	STS		AL_ACTIVA, R16
                                 
0000d0 e005                      	LDI		R16, MODE_RING
0000d1 2f40                      	MOV		MODE, R16
                                 
                                 SALIR_CHECK_ALARM:
0000d2 9508                      	RET
                                 
                                 CONTROL_RING:
                                 
0000d3 9100 0112                 	LDS		R16, AL_ACTIVA
0000d5 3045                      	CPI		MODE, MODE_RING
0000d6 f411                      	BRNE	APAGAR_RING
                                 
                                 	// Encendemos buzzer
0000d7 9a5e                      	SBI		PORTD, PORTD6
0000d8 9508                      	RET
                                 
                                 APAGAR_RING:
                                 
                                 	// Apagamos buzzer
0000d9 985e                      	CBI		PORTD, PORTD6
0000da 9508                      	RET
                                 
                                 CHECK_SILENCIO_RING:
0000db 3045                      	CPI		MODE, MODE_RING
0000dc f499                      	BRNE	SALIR_SILENCIO_RING
                                 
0000dd 9b4f                      	SBIS	PIND, PIND7
0000de c001                      	RJMP	CONFIRMAR_SILENCIO
0000df 9508                      	RET
                                 
                                 CONFIRMAR_SILENCIO:
0000e0 940e 00a8                 	CALL	DELAY_REBOTE
0000e2 9b4f                      	SBIS	PIND, PIND7
0000e3 c001                      	RJMP	APAGAR_ALARMA
0000e4 9508                      	RET
                                 
                                 APAGAR_ALARMA:
                                 	
0000e5 2700                      	CLR		R16
0000e6 9300 0112                 	STS		AL_ACTIVA, R16
                                 
0000e8 e000                      	LDI		R16, MODE_CLOCK
0000e9 2f40                      	MOV		MODE, R16
                                 
0000ea b109                      	IN		R16, PIND
0000eb 9300 0108                 	STS		PREV_D7, R16
                                 
                                 ESPERA_SUELTA_SILENCIO:
0000ed 994f                      	SBIC	PIND, PIND7
0000ee c001                      	RJMP	SALIR_SILENCIO_RING
0000ef cffd                      	RJMP	ESPERA_SUELTA_SILENCIO
                                 
                                 SALIR_SILENCIO_RING:
0000f0 9508                      	RET
                                 
                                 RESET_ALARMA_CAMBIO_MINUTO:
0000f1 9100 010b                 	LDS		R16, SEGUNDOS
0000f3 3001                      	CPI		R16, 1
0000f4 f419                      	BRNE	SALIR_RESET_ALARMA
                                 
0000f5 2700                      	CLR		R16
0000f6 9300 0112                 	STS		AL_ACTIVA, R16
                                 
                                 SALIR_RESET_ALARMA:
0000f8 9508                      	RET
                                 
                                 CHECK_SET_CLOCK:
0000f9 9b32                      	SBIS	PINC, PINC2
0000fa 940e 0172                 	CALL	BOTON_INC_HORA
                                 
0000fc 9b33                      	SBIS	PINC, PINC3
0000fd 940e 017c                 	CALL	BOTON_DEC_HORA
                                 
0000ff 9b34                      	SBIS	PINC, PINC4
000100 940e 0186                 	CALL	BOTON_INC_MIN
                                 
000102 9b35                      	SBIS	PINC, PINC5
000103 940e 0190                 	CALL	BOTON_DEC_MIN
                                 
000105 9508                      	RET
                                 CHECK_SET_DATE:
000106 9b32                      	SBIS	PINC, PINC2
000107 940e 019a                 	CALL	BOTON_INC_DIA
                                 
000109 9b33                      	SBIS	PINC, PINC3
00010a 940e 01a4                 	CALL	BOTON_DEC_DIA
                                 
00010c 9b34                      	SBIS	PINC, PINC4
00010d 940e 01ae                 	CALL	BOTON_INC_MES
                                 
00010f 9b35                      	SBIS	PINC, PINC5
000110 940e 01b8                 	CALL	BOTON_DEC_MES
                                 
000112 9508                      	RET
                                 
                                 CHECK_SET_ALARM:
000113 9b32                      	SBIS	PINC, PINC2
000114 940e 0120                 	CALL	BOTON_INC_AL_HORA
                                 
000116 9b33                      	SBIS	PINC, PINC3
000117 940e 012a                 	CALL	BOTON_DEC_AL_HORA
                                 
000119 9b34                      	SBIS	PINC, PINC4
00011a 940e 0134                 	CALL	BOTON_INC_AL_MIN
                                 
00011c 9b35                      	SBIS	PINC, PINC5
00011d 940e 013e                 	CALL	BOTON_DEC_AL_MIN
                                 
00011f 9508                      	RET
                                 
                                 BOTON_INC_AL_HORA:
000120 940e 00a8                 	CALL	DELAY_REBOTE
000122 9b32                      	SBIS	PINC, PINC2
000123 c001                      	RJMP	CONFIRM_INC_AL_HORA
000124 9508                      	RET
                                 
                                 CONFIRM_INC_AL_HORA:
000125 940e 0148                 	CALL	INC_AL_HORAS
                                 
                                 ESPERA_SUELTA_INC_AL_HORA:
000127 9932                      	SBIC	PINC, PINC2
000128 9508                      	RET
000129 cffd                      	RJMP	ESPERA_SUELTA_INC_AL_HORA
                                 
                                 
                                 BOTON_DEC_AL_HORA:
00012a 940e 00a8                 	CALL	DELAY_REBOTE
00012c 9b33                      	SBIS	PINC, PINC3
00012d c001                      	RJMP	CONFIRM_DEC_AL_HORA
00012e 9508                      	RET
                                 
                                 CONFIRM_DEC_AL_HORA:
00012f 940e 0151                 	CALL	DEC_AL_HORAS
                                 
                                 ESPERA_SUELTA_DEC_AL_HORA:
000131 9933                      	SBIC	PINC, PINC3
000132 9508                      	RET
000133 cffd                      	RJMP	ESPERA_SUELTA_DEC_AL_HORA
                                 
                                 
                                 BOTON_INC_AL_MIN:
000134 940e 00a8                 	CALL	DELAY_REBOTE
000136 9b34                      	SBIS	PINC, PINC4
000137 c001                      	RJMP	CONFIRM_INC_AL_MIN
000138 9508                      	RET
                                 
                                 CONFIRM_INC_AL_MIN:
000139 940e 015d                 	CALL	INC_AL_MINUTOS
                                 
                                 ESPERA_SUELTA_INC_AL_MIN:
00013b 9934                      	SBIC	PINC, PINC4
00013c 9508                      	RET
00013d cffd                      	RJMP	ESPERA_SUELTA_INC_AL_MIN
                                 
                                 
                                 BOTON_DEC_AL_MIN:
00013e 940e 00a8                 	CALL	DELAY_REBOTE
000140 9b35                      	SBIS	PINC, PINC5
000141 c001                      	RJMP	CONFIRM_DEC_AL_MIN
000142 9508                      	RET
                                 
                                 CONFIRM_DEC_AL_MIN:
000143 940e 0166                 	CALL	DEC_AL_MINUTOS
                                 
                                 ESPERA_SUELTA_DEC_AL_MIN:
000145 9935                      	SBIC	PINC, PINC5
000146 9508                      	RET
000147 cffd                      	RJMP	ESPERA_SUELTA_DEC_AL_MIN
                                 
                                 INC_AL_HORAS:
000148 9100 0110                 	LDS		R16, AL_HORAS
00014a 9503                      	INC		R16
00014b 3108                      	CPI		R16, 24
00014c f409                      	BRNE	GUARDAR_INC_AL_HORAS
                                 
00014d 2700                      	CLR		R16
                                 
                                 GUARDAR_INC_AL_HORAS:
00014e 9300 0110                 	STS		AL_HORAS, R16
000150 9508                      	RET
                                 
                                 
                                 DEC_AL_HORAS:
000151 9100 0110                 	LDS		R16, AL_HORAS
000153 3000                      	CPI		R16, 0
000154 f421                      	BRNE	RESTAR_AL_HORA
                                 
000155 e107                      	LDI		R16, 23
000156 9300 0110                 	STS		AL_HORAS, R16
000158 9508                      	RET
                                 
                                 RESTAR_AL_HORA:
