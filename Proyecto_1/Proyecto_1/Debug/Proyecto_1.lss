                                 CHECK_MODE_BUTTON:
                                 	
00023d b109                      	IN		R16, PIND // Leemos el estado actual
00023e 9110 0108                 	LDS		R17, PREV_D7 // Cargamos el estado anterior
                                 
000240 ff17                      	SBRS	R17, 7
000241 c00d                      	RJMP	GUARDAR_SALIR // Si ya era 0, no cambio
                                 
000242 ff07                      	SBRS	R16, 7
000243 c001                      	RJMP	CONFIRMAR_MODO // Revisamos si el bit 7 es 0
                                 
000244 c00a                      	RJMP	GUARDAR_SALIR
                                 
                                 CONFIRMAR_MODO:
000245 940e 00a8                 	CALL	DELAY_REBOTE
000247 9b4f                      	SBIS	PIND, PIND7
000248 c001                      	RJMP	HACER_CAMBIO_MODO
000249 c005                      	RJMP	GUARDAR_SALIR
                                 
                                 HACER_CAMBIO_MODO:
00024a 940e 0253                 	CALL	CHANGE_MODE
                                 
                                 ESPERA_SUELTA_MODO:
00024c 994f                      	SBIC	PIND, PIND7
00024d c001                      	RJMP	GUARDAR_SALIR
00024e cffd                      	RJMP	ESPERA_SUELTA_MODO
                                 
                                 GUARDAR_SALIR:
00024f b109                      	IN		R16, PIND
000250 9300 0108                 	STS		PREV_D7, R16 // Guardamos la actual como anterior
000252 9508                      	RET
                                 
                                 CHANGE_MODE:
000253 9543                      	INC		MODE
000254 3045                      	CPI		MODE, MAX_MODES // Compara si ya llego al último
                                 
000255 f409                      	BRNE	NO_RESET_MODE
000256 2744                      	CLR		MODE
                                 
                                 NO_RESET_MODE:
000257 940e 027d                 	CALL	LOAD_MODE_MENSAJE // Muestra el estado
                                 
000259 e001                      	LDI		R16, 1
00025a 9300 0105                 	STS		MENSAJE, R16
                                 
00025c ee08                      	LDI		R16, LOW(1000)
00025d 9300 0106                 	STS		MEN_LOW, R16
00025f e003                      	LDI		R16, HIGH(1000)
000260 9300 0107                 	STS		MEN_HIGH, R16
                                 
000262 9508                      	RET
                                 /****************************************/
                                 // NON-Interrupt subroutines
                                 
                                 INIT_TIMER0:
                                 
000263 e002                      	LDI		R16, (1<<WGM01) // Lo ponemos en modo CTC
000264 bd04                      	OUT		TCCR0A, R16
                                 
000265 e002                      	LDI		R16, (1<<CS01) // Prescaler 8      
000266 bd05                      	OUT		TCCR0B, R16
                                 
000267 e70c                      	LDI		R16, T0VALUE // Comparamos el timer con n
000268 bd07                      	OUT		OCR0A, R16
                                 
000269 e002                      	LDI		R16, (1<<OCIE0A) // Habilitamos compare match A
00026a 9300 006e                 	STS		TIMSK0, R16
00026c 9508                      	RET
                                 
                                 
                                 INIT_TIMER1:
                                 	
00026d e000                      	LDI		R16, 0x00
00026e 9300 0080                 	STS		TCCR1A, R16                 
                                 
000270 e00b                      	LDI		R16, (1<<WGM12) | (1<<CS11) | (1<<CS10)
000271 9300 0081                 	STS		TCCR1B, R16 // Habilitamos CTC y prescaler de 64
                                 
000273 e30d                      	LDI		R16, HIGH(T1VALUE)
000274 9300 0089                 	STS		OCR1AH, R16
000276 e008                      	LDI		R16, LOW(T1VALUE)
000277 9300 0088                 	STS		OCR1AL, R16
                                 
000279 e002                      	LDI		R16, (1<<OCIE1A) // Habilitamos compare match A
00027a 9300 006f                 	STS		TIMSK1, R16
00027c 9508                      	RET
                                 
                                 LOAD_MODE_MENSAJE:
                                 
                                 	// Cargamos en Z la direccion
00027d e0f8                      	LDI		ZH, HIGH(TABLA_MODOS << 1)
00027e eae0                      	LDI		ZL, LOW(TABLA_MODOS << 1)
                                 
                                 	// Lo corremos
00027f 2f24                      	MOV		R18, MODE
000280 0f22                      	LSL		R18
000281 0f22                      	LSL		R18
                                 
                                 	// Sumamos los valores y manejamos el carry
000282 2733                      	CLR		R19
000283 0fe2                      	ADD		ZL, R18
000284 1ff3                      	ADC		ZH, R19	
                                 
                                 	// Leemos y mostramos
000285 9105                      	LPM		R16, Z+
000286 9300 0100                 	STS		DISP0, R16
                                 
000288 9105                      	LPM		R16, Z+
000289 9300 0101                 	STS		DISP1, R16
                                 
00028b 9105                      	LPM		R16, Z+
00028c 9300 0102                 	STS		DISP2, R16
                                 
00028e 9105                      	LPM		R16, Z+
00028f 9300 0103                 	STS		DISP3, R16
                                 
000291 9508                      	RET
                                 
                                 NUM_A_7SEG:
000292 3000                      	CPI		R16, 0
000293 f099                      	BREQ	NUM0
000294 3001                      	CPI		R16, 1
000295 f099                      	BREQ	NUM1
000296 3002                      	CPI		R16, 2
000297 f099                      	BREQ	NUM2
000298 3003                      	CPI		R16, 3
000299 f099                      	BREQ	NUM3
00029a 3004                      	CPI		R16, 4
00029b f099                      	BREQ	NUM4
00029c 3005                      	CPI		R16, 5
00029d f099                      	BREQ	NUM5
00029e 3006                      	CPI		R16, 6
00029f f099                      	BREQ	NUM6
0002a0 3007                      	CPI		R16, 7
0002a1 f099                      	BREQ	NUM7
0002a2 3008                      	CPI		R16, 8
0002a3 f099                      	BREQ	NUM8
0002a4 3009                      	CPI		R16, 9
0002a5 f099                      	BREQ	NUM9
0002a6 9508                      	RET
                                 
                                 NUM0:
0002a7 e30f                      	LDI		R16, SEG_0
0002a8 9508                      	RET
                                 NUM1:
0002a9 e006                      	LDI		R16, SEG_1
0002aa 9508                      	RET
                                 NUM2:
0002ab e50b                      	LDI		R16, SEG_2
0002ac 9508                      	RET
                                 NUM3:
0002ad e40f                      	LDI		R16, SEG_3
0002ae 9508                      	RET
                                 NUM4:
0002af e606                      	LDI		R16, SEG_4
0002b0 9508                      	RET
                                 NUM5:
0002b1 e60d                      	LDI		R16, SEG_5
0002b2 9508                      	RET
                                 NUM6:
0002b3 e70d                      	LDI		R16, SEG_6
0002b4 9508                      	RET
                                 NUM7:
0002b5 e007                      	LDI		R16, SEG_7
0002b6 9508                      	RET
                                 NUM8:
0002b7 e70f                      	LDI		R16, SEG_8
