                                 	// Segmento a
0002c1 ff10                      	SBRS	R17, 0
0002c2 9828                      	CBI		PORTB, PORTB0
0002c3 fd10                      	SBRC	R17, 0
0002c4 9a28                      	SBI		PORTB, PORTB0
                                 
                                 	// Segmento b
0002c5 ff11                      	SBRS	R17, 1
0002c6 9829                      	CBI		PORTB, PORTB1
0002c7 fd11                      	SBRC	R17, 1
0002c8 9a29                      	SBI		PORTB, PORTB1
                                 
                                 	// Segmento c
0002c9 ff12                      	SBRS	R17, 2
0002ca 982a                      	CBI		PORTB, PORTB2
0002cb fd12                      	SBRC	R17, 2
0002cc 9a2a                      	SBI		PORTB, PORTB2
                                 
                                 	// Segmento d
0002cd ff13                      	SBRS	R17, 3
0002ce 982b                      	CBI		PORTB, PORTB3
0002cf fd13                      	SBRC	R17, 3
0002d0 9a2b                      	SBI		PORTB, PORTB3
                                 
                                 	// Segmento e
0002d1 ff14                      	SBRS	R17, 4
0002d2 982c                      	CBI		PORTB, PORTB4
0002d3 fd14                      	SBRC	R17, 4
0002d4 9a2c                      	SBI		PORTB, PORTB4
                                 
                                 	// Segmento f
0002d5 ff15                      	SBRS	R17, 5
0002d6 982d                      	CBI		PORTB, PORTB5
0002d7 fd15                      	SBRC	R17, 5
0002d8 9a2d                      	SBI		PORTB, PORTB5
                                 
                                 	// Segmento g
0002d9 ff16                      	SBRS	R17, 6
0002da 9840                      	CBI		PORTC, PORTC0
0002db fd16                      	SBRC	R17, 6
0002dc 9a40                      	SBI		PORTC, PORTC0
                                 
0002dd 9508                      	RET
                                 
                                 MUX_DISPLAY:
                                 	
