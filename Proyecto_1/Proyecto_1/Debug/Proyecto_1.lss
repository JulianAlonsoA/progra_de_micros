000222 3012                      	CPI		R17, 2
000223 f051                      	BREQ	MAX_FEBRERO
                                 
000224 3014                      	CPI		R17, 4
000225 f051                      	BREQ	MAX_30
000226 3016                      	CPI		R17, 6
000227 f041                      	BREQ	MAX_30
000228 3019                      	CPI		R17, 9
000229 f031                      	BREQ	MAX_30
00022a 301b                      	CPI		R17, 11
00022b f021                      	BREQ	MAX_30
                                 
